# ============================================================
#  LuckyTech Academy — .env.example
#  Yeh file copy karke .env banao aur apni values bharo
#  Command: cp .env.example .env
# ============================================================


# ─── MySQL Database ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=luckytech_exam


# ─── JWT Authentication ──────────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=7d


# ─── Server ──────────────────────────────────────────────────
PORT=5000
FRONTEND_URL=http://localhost:5173


# ─── Admin Panel ─────────────────────────────────────────────
ADMIN_KEY=Lucky@dm!n


# ─── Exam Settings ───────────────────────────────────────────
EXAM_QUESTIONS=10


# ─── Anthropic AI (Optional) ─────────────────────────────────
ANTHROPIC_API_KEY=
